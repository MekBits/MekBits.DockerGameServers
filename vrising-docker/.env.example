# ---- Update behaviour ----
UPDATE_ON_START=false

# ---- Server identity ----
SERVER_NAME=My V Rising Server
SERVER_DESCRIPTION=
SERVER_PASSWORD=
SAVE_NAME=world1
MAX_USERS=40
MAX_ADMINS=4
SERVER_FPS=30

# ---- Networking ----
GAME_PORT=9876
QUERY_PORT=27015

# ---- Listing / EOS ----
LIST_ON_STEAM=true
LIST_ON_EOS=true
SECURE=true

# ---- Persistence ----
AUTO_SAVE_COUNT=40
AUTO_SAVE_INTERVAL=120
COMPRESS_SAVE_FILES=true

# ---- Game presets (optional; leave empty for defaults) ----
GAME_SETTINGS_PRESET=
GAME_DIFFICULTY_PRESET=

# ---- Debug / admin ----
ADMIN_ONLY_DEBUG_EVENTS=true
DISABLE_DEBUG_EVENTS=false

# ---- RCON ----
RCON_ENABLED=false
RCON_PORT=25575
RCON_PASSWORD=

# ---- API ----
API_ENABLED=false

# ---- Runtime ----
USE_XVFB=true

# ---- Backups ----
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_KEEP=24

# ---- Notifications ----
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
