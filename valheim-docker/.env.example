# ---- Update behaviour ----
UPDATE_ON_START=false

# ---- Server identity ----
SERVER_NAME=My Valheim Server
WORLD_NAME=Dedicated
SERVER_PASSWORD=change-me
SERVER_PUBLIC=true

# ---- Networking ----
SERVER_PORT=2456

# ---- Crossplay ----
CROSSPLAY=false

# ---- Access control (optional; when set, OVERWRITES the on-disk list) ----
# Comma/space separated SteamID64s.
# ADMIN_IDS=76561198000000000 76561198000000001
# BANNED_IDS=
# PERMITTED_IDS=

# ---- Mods (opt-in) ----
BEPINEX=false
# BEPINEX_DOWNLOAD_URL=https://thunderstore.io/package/download/denikson/BepInExPack_Valheim/5.4.2333/

# ---- Advanced launch flags (optional) ----
# EXTRA_ARGS=-preset hard

# ---- Backups ----
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_KEEP=24

# ---- Notifications ----
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
